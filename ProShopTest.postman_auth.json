                      "// Login user thường để lấy cookie",
                      "pm.sendRequest({",
                      "    url: pm.environment.get('baseUrl') + '/api/users/auth',",
                      "    method: 'POST',",
                      "    header: { 'Content-Type': 'application/json' },",
                      "    body: {",
                      "        mode: 'raw',",
                      "        raw: JSON.stringify({ email: 'testuser123@email.com', password: '123456' })",
                      "    }",
                      "}, function(err, res) {",
                      "    if (!err) {",
                      "        const userJwt = res.cookies.get('jwt');",
                      "        pm.environment.set('userToken', userJwt);",
                      "    }",
                      "});"
                    ],
