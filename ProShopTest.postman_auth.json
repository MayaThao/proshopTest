        "exec": [
          "const expected = pm.variables.get(\"expectedStatus\");",
          "const expectedCodes = expected",
          "  ? expected.split(\",\").map(s => parseInt(s.trim()))",
          "  : [200, 201];",
          "",
          "pm.variables.unset(\"expectedStatus\");",
          "",
          "if (!expectedCodes.includes(pm.response.code)) {",
          "  pm.sendRequest({",
          "    url: pm.environment.get(\"jiraUrl\") + \"/rest/api/2/issue\",",
          "    method: \"POST\",",
          "    header: {",
          "      \"Authorization\": pm.environment.get(\"jiraToken\"),",
          "      \"Content-Type\": \"application/json\"",
          "    },",
          "    body: {",
          "      mode: \"raw\",",
          "      raw: JSON.stringify({",
          "        fields: {",
          "          project: { key: pm.environment.get(\"jiraProject\") },",
          "          summary: \"FAIL: \" + pm.info.requestName,",
          "          description: \"📌 *Chi tiết:* Request thất bại ngoài ý muốn.\"",
          "                       + \"\\n\\n📥 *Input:*\\n\" + pm.request.method + \" \" + pm.request.url",
          "                       + \"\\n\\nBody: \" + (pm.request.body ? pm.request.body.toString() : \"none\")",
          "                       + \"\\n\\n🖱️ *Thao tác:*\\n1. Chạy Postman Collection Runner\"",
          "                       + \"\\n2. Request: \" + pm.request.method + \" \" + pm.request.url",
          "                       + \"\\n3. Expected: \" + expectedCodes.join(\",\")",
          "                       + \"\\n4. Actual: \" + pm.response.code",
          "                       + \"\\n\\n📸 *Screenshot:*\\n{code}\"",
          "                       + \"Status: \" + pm.response.code",
          "                       + \"\\nResponse: \" + pm.response.text().substring(0, 500)",
          "                       + \"{code}\",",
          "          issuetype: { name: \"Bug\" },",
          "          priority: { name: \"High\" }",
          "        }",
          "      })",
          "    }",
          "  });",
          "}"
        ]
      }
    }
  ]
}
