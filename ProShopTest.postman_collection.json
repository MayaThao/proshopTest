        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const expected = pm.variables.get(\"expectedStatus\");\r",
          "const expectedCodes = expected\r",
          "  ? expected.split(\",\").map(s => parseInt(s.trim()))\r",
          "  : [200, 201];\r",
          "\r",
          "pm.variables.unset(\"expectedStatus\");\r",
          "\r",
          "if (!expectedCodes.includes(pm.response.code)) {\r",
          "  pm.sendRequest({\r",
          "    url: pm.environment.get(\"jiraUrl\") + \"/rest/api/2/issue\",\r",
          "    method: \"POST\",\r",
          "    header: {\r",
          "      \"Authorization\": pm.environment.get(\"jiraToken\"),\r",
          "      \"Content-Type\": \"application/json\"\r",
          "    },\r",
          "    body: {\r",
          "      mode: \"raw\",\r",
          "      raw: JSON.stringify({\r",
          "        fields: {\r",
          "          project:     { key: pm.environment.get(\"jiraProject\") },\r",
          "          summary:     \"FAIL: \" + pm.info.requestName,\r",
          "          description: \"📌 *Chi tiết:* Request thất bại ngoài ý muốn.\"\r",
          "                       + \"\\n\\n📥 *Input:*\\n\" + pm.request.method + \" \" + pm.request.url\r",
          "                       + \"\\n\\nBody: \" + (pm.request.body ? pm.request.body.toString() : \"none\")\r",
          "                       + \"\\n\\n🖱️ *Thao tác:*\\n1. Chạy Postman Collection Runner\"\r",
          "                       + \"\\n2. Request: \" + pm.request.method + \" \" + pm.request.url\r",
          "                       + \"\\n3. Expected: \" + expectedCodes.join(\",\")\r",
          "                       + \"\\n4. Actual: \" + pm.response.code\r",
          "                       + \"\\n\\n📸 *Screenshot:*\\n{code}\"\r",
          "                       + \"Status: \" + pm.response.code\r",
          "                       + \"\\nResponse: \" + pm.response.text().substring(0, 500)\r",
          "                       + \"{code}\",\r",
          "          issuetype:   { name: \"Bug\" },\r",
          "          priority:    { name: \"High\" }\r",
          "        }\r",
          "      })\r",
          "    }\r",
          "  });\r",
          "}"
        ]
      }
    }
