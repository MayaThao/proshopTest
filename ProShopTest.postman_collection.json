                      "pm.test(\"TC_1.1: Status 200\", () => {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"TC_1.1: Trả về userInfo\", () => {\r",
                      "    const body = pm.response.json();\r",
                      "    pm.expect(body).to.have.property('email');\r",
                      "    pm.expect(body).to.have.property('name');\r",
                      "});\r",
                      "\r",
                      "pm.test(\"TC_1.1: Cookie jwt được set\", () => {\r",
                      "    pm.expect(pm.cookies.get('jwt')).to.not.be.undefined;\r",
                      "});\r",
                      "\r",
                      "// Lưu jwt vào Environment \r",
                      "const jwt = pm.cookies.get('jwt');\r",
                      "pm.environment.set('jwt', jwt);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
